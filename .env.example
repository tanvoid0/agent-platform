# Copy to `.env` (never commit `.env`). Values must match llm-orchestrator where applicable.
#
# LITELLM_MASTER_KEY must match ORCHESTRATOR_MASTER_KEY or LITELLM_MASTER_KEY on the orchestrator
# (character-for-character; no extra quotes in one file and not the other).

LITELLM_MASTER_KEY=

# OpenAI-compatible base URL including /v1 (no trailing slash required).
# Host: http://127.0.0.1:18408/v1
# Agent Platform in Docker reaching the host orchestrator: http://host.docker.internal:18408/v1

LLM_ORCHESTRATOR_BASE_URL=http://127.0.0.1:18408/v1
