# Copy to `.env` (never commit `.env`). Values must match llm-orchestrator where applicable.
#
# Only uncommented KEY=value lines are loaded by python-dotenv. Commented lines are hints; the app
# uses code defaults for those keys (see app/*.py). Uncomment when you need an override.
#
# API key for Bearer auth to llm-orchestrator (same secret as on the orchestrator).

ORCHESTRATOR_MASTER_KEY=

# OpenAI-compatible base URL including /v1 (no trailing slash required).
# Host: http://127.0.0.1:18408/v1
# Agent Platform in Docker reaching the host orchestrator: http://host.docker.internal:18408/v1
# (or keep 127.0.0.1 below — agent-platform rewrites to host.docker.internal inside containers.)

LLM_ORCHESTRATOR_BASE_URL=http://127.0.0.1:18408/v1
# Proxy HTTP surface (chat, models, embeddings): http://127.0.0.1:18408/docs

# HTTP timeout (seconds) for Agent Platform → llm-orchestrator (planner, DAG tasks, Flow chat proxy).
# Default 600 matches Flow UI chat (VITE_API_CHAT_TIMEOUT_MS). Raise if Ollama logs show
# "aborting completion request due to client closing the connection" while generation is still running.
# AGENT_PLATFORM_ORCHESTRATOR_TIMEOUT_SECONDS=600

# Ollama (host env, not this file): set OLLAMA_DEBUG_LOG_REQUESTS=1 for per-request logs.
# OLLAMA_CONTEXT_LENGTH must not exceed the model's trained context (e.g. Gemma n_ctx_train=131072);
# higher values log "requested context size too large for model" and are clamped.

# Set to 0 only if you must use loopback from inside Docker (sidecar on same network).
# AGENT_PLATFORM_ORCHESTRATOR_DOCKER_FIX=1

# Optional model aliases from llm-orchestrator config.yaml (must exist on the proxy — see GET /v1/models).
# When unset, chat/completions requests omit `model` so the orchestrator applies its configured default.
# Example names are not guaranteed on your orchestrator; `local` only works if you defined that alias in config.yaml.
# PLANNER_MODEL=local
# SUBAGENT_MODEL=local

# Planning and sub-DAG expansion: retry on invalid JSON / failed validation (local models often drift). Min 1.
# Last attempt uses PLANNER_FALLBACK_MODEL when set and different from PLANNER_MODEL.
# AGENT_PLATFORM_PLAN_MAX_ATTEMPTS=3
# PLANNER_FALLBACK_MODEL=

# SQLite path (default: data/agent_platform.db under cwd — see app/database.py). WAL enabled at startup.
# AGENT_PLATFORM_DB_PATH=data/agent_platform.db

# Per-project file sandboxes (Deliverables + workspace_* DAG tools). Default: {parent of DB}/workspaces.
# In Docker Compose, this is set to /app/data/workspaces alongside the DB volume.
# AGENT_PLATFORM_WORKSPACE_ROOT=data/workspaces

# Optional wall-clock limits (unset = no limit). Planning wraps the planner LLM call;
# run max applies to the execution phase between DAG waves (not per-HTTP-call to the orchestrator).
# AGENT_PLATFORM_PLAN_TIMEOUT_SECONDS=300
# AGENT_PLATFORM_RUN_MAX_SECONDS=3600

# Cap parallel runnable tasks (unset = unlimited). Ready tasks run in ascending TaskNode id order.
# AGENT_PLATFORM_DAG_MAX_CONCURRENT_TASKS=

# Auto-approve: skip the human gate after planning (trusted / dev only). Same as POST /processes {"auto_approve": true}.
# Truthy: 1, true, yes, on.
# AGENT_PLATFORM_AUTO_APPROVE=0

# Optional: CORS for Vite dev (comma-separated origins). Default is `*` if unset.
# CORS_ALLOW_ORIGINS=http://127.0.0.1:5174

# Optional: public API base URL for the minimal Jinja UI (e.g. if the browser must call a different host).
# AGENT_PLATFORM_PUBLIC_API=http://127.0.0.1:18410

# Optional: require Authorization: Bearer <token> on /processes, /teams, /api/v1/* (single shared secret).
# If you set this, the Flow UI must set the same value in web/.env.local as:
#   VITE_AGENT_PLATFORM_API_KEY=<same string>
# If unset, the browser can call the API without a Bearer key (local dev only).
AGENT_PLATFORM_API_KEY=

# Optional: require client_id on POST /processes (JSON body or X-Agent-Platform-Client header).
# AGENT_PLATFORM_REQUIRE_CLIENT_ID=0

# Reliability: planning/DAG run in FastAPI BackgroundTasks. If the server stops mid-run, use
# POST /processes/{id}/sync to recover — see docs/reliability-invariants.md.

# Phase 3 — tools (see app/tools_policy.py); v1 is prompt-only unless enabled below.
# Budget is enforced per run (Run.tool_invocations_used).
# AGENT_PLATFORM_TOOLS_ENABLED=0
# AGENT_PLATFORM_TOOLS_ALLOWLIST=echo,http_fetch,orchestrator_health,list_models
# AGENT_PLATFORM_TOOL_BUDGET_PER_RUN=0

# http_fetch tool: comma-separated URL prefixes (scheme + host + path). Required for http_fetch.
# AGENT_PLATFORM_HTTP_FETCH_ALLOWLIST=http://127.0.0.1:18408,https://example.com
# AGENT_PLATFORM_HTTP_FETCH_MAX_BYTES=262144
# AGENT_PLATFORM_HTTP_FETCH_TIMEOUT_SECONDS=30

# MCP Streamable HTTP tools (mcp_call, mcp_list_tools): comma-separated URL prefixes for MCP endpoints.
# Optional Authorization header for MCP HTTP requests (e.g. Bearer …).
# Optional timeout seconds (default 120).
# AGENT_PLATFORM_MCP_ENDPOINT_ALLOWLIST=http://127.0.0.1:18409/mcp
# AGENT_PLATFORM_MCP_AUTHORIZATION=
# AGENT_PLATFORM_MCP_TIMEOUT_SECONDS=120

# --- LLM context limits (server-side; Flow UI does not trim prompts) ---
# Model context window for budgeting prompts sent to the orchestrator (tiktoken estimate + margin).
# AGENT_PLATFORM_CONTEXT_WINDOW_TOKENS=32768
# Reserved completion budget and safety margin subtracted from the window for prompt fitting.
# AGENT_PLATFORM_MAX_OUTPUT_TOKENS=4096
# AGENT_PLATFORM_CONTEXT_SAFETY_MARGIN=512
# tiktoken encoding name (default cl100k_base — good for many OpenAI-style models).
# AGENT_PLATFORM_TOKEN_ENCODING=cl100k_base
# Per tool result appended to the tool-calling loop (then full shrink may apply).
# AGENT_PLATFORM_TOOL_RESULT_MAX_TOKENS=12000
# Sub-DAG expansion: max tokens of parent task output embedded in the planner prompt.
# AGENT_PLATFORM_SUBDAG_PARENT_MAX_TOKENS=4000
# Optional: LLM-condense oversized dependency chunks before proportional fitting (extra cost).
# AGENT_PLATFORM_CONTEXT_SUMMARIZE=0
# AGENT_PLATFORM_CONTEXT_SUMMARIZE_MIN_TOKENS=6000
# AGENT_PLATFORM_CONTEXT_SUMMARIZE_MAX_OUTPUT_TOKENS=900
# AGENT_PLATFORM_CONTEXT_SUMMARIZE_MAX_INPUT_TOKENS=16000

# Phase 3 — recursive sub-DAG expansion after a task completes (planner sets subdecompose on a subagent).
# Defaults allow granular follow-on tasks; set MAX_EXPANSIONS=0 to disable entirely.
# AGENT_PLATFORM_SUBDECOMP_MAX_EXPANSIONS=48
# AGENT_PLATFORM_SUBDECOMP_MAX_NEW_TASKS=48
# Optional: max expansion depth (planner tasks = 0; each expansion adds +1). Unset = unlimited.
# AGENT_PLATFORM_SUBDECOMP_MAX_DEPTH=

# --- Flow UI (Vite): set these in web/.env.local if you need overrides ---
# Default HTTP timeouts for browser → agent-platform API (fetch); chat uses a longer default.
# VITE_API_FETCH_TIMEOUT_MS=120000
# VITE_API_CHAT_TIMEOUT_MS=600000
