# Copy to `.env` (never commit `.env`).
#
# **Non-secret settings:** edit `config/agent_platform.yaml` (URLs, DB path, planner flags, etc.).
# **Secrets:** set only here or in the process environment — never commit real keys.
#
# Precedence: shell environment > `.env` > `config/agent_platform.yaml` > code defaults.
#
# Optional: point to another YAML file
# AGENT_PLATFORM_CONFIG_YAML=/path/to/agent_platform.yaml
#
# --- Lean server ---
# Backend ships with `/config` (LLM proxy settings) and `/ui` (process demo).
# Optional Flow UI lives in ../flow-ui/ — start with root `docker compose --profile ui`.
#
# Cross-origin browser access when Flow UI is on another host/port:
# CORS_ALLOW_ORIGINS=http://127.0.0.1:3333,http://127.0.0.1:18408
#
# For a single-container run with embedded LLM proxy, see `docker-compose.agent-only.yml`:
#   - AGENT_PLATFORM_DB_PATH, AGENT_PLATFORM_WORKSPACE_ROOT, CONFIG_DIR, CONFIG_PATH
#   - LLM_ORCHESTRATOR_BASE_URL=http://127.0.0.1:18410/v1 (same process as the API)
# External microservices call the HTTP API with the master key; see `/api-guide` and
# `scripts/external_microservice_example.py`.

# --- secrets (keep in `.env` only) ---
AGENT_PLATFORM_MASTER_KEY=

# Optional cloud / API keys (embedded LLM proxy)
# GEMINI_API_KEY=
# AIMLAPI_API_KEY=
# AIMLAPI_OPENAI_BASE=https://api.aimlapi.com/v1
# LM_STUDIO_API_KEY=

# Optional: require `Authorization: Bearer` on `/api/v1/*` (config UI auth bar or flow-ui `.env.local` as VITE_AGENT_PLATFORM_MASTER_KEY)

# Docker: rewrite 127.0.0.1 → host.docker.internal for LM_STUDIO_API_BASE / OLLAMA_API_BASE (default on in container).
# AGENT_PLATFORM_LOCAL_LLM_DOCKER_FIX=0

# --- performance tuning (optional) ---
# Uvicorn workers: docker-compose defaults to 1. With SQLite (default DB), compose clamps to 1 worker even if you set >1.
# AGENT_PLATFORM_UVICORN_WORKERS=8
# AGENT_PLATFORM_UVICORN_KEEPALIVE_SECONDS=30
#
# DAG scheduler concurrency for dependency-ready tasks. Keep below provider/API bottlenecks.
# AGENT_PLATFORM_DAG_MAX_CONCURRENT_TASKS=12
#
# Thread pools for Python/native libraries inside the container.
# UV_THREADPOOL_SIZE=16
# OMP_NUM_THREADS=16
# OPENBLAS_NUM_THREADS=16
# MKL_NUM_THREADS=16
# NUMEXPR_NUM_THREADS=16
