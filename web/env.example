# =============================================================================
# Vite / Flow UI — copy to `web/.env.local` (gitignored). Never commit secrets.
# =============================================================================
#
# Agent Platform FastAPI defaults to http://127.0.0.1:18410 (embeds OpenAI-compatible /v1; see repo README).
# LLM proxy env and config.yaml are configured in the SERVER `.env` / Settings → LLM proxy, not here.

# --- Required when the API enforces auth (server has AGENT_PLATFORM_MASTER_KEY set) ---
# Must be the SAME string as `AGENT_PLATFORM_MASTER_KEY` in the parent `agent-platform/.env`.
# If the server `.env` leaves AGENT_PLATFORM_MASTER_KEY empty, leave this empty too.
VITE_AGENT_PLATFORM_MASTER_KEY=

# --- API origin for browser fetches (Vite dev) ---
# Production: same-origin as `/flow`; leave unset in build if you rely on relative URLs.
# Dev: point at the running uvicorn (default port 18410).
VITE_API_ORIGIN=http://127.0.0.1:18410

# --- Optional: chat / LLM model hints (see also model-config.ts) ---
# VITE_OLLAMA_MODEL=
# VITE_LM_STUDIO_MODEL=
