# =============================================================================
# Vite / Flow UI — copy to `web/.env.local` (gitignored). Never commit secrets.
# =============================================================================
#
# Agent Platform FastAPI defaults to http://127.0.0.1:18410 (see repo README).
# llm-orchestrator defaults to http://127.0.0.1:18408 — configured in the SERVER
# `.env` at the agent-platform repo root, not here.

# --- Required when the API enforces auth (server has AGENT_PLATFORM_API_KEY set) ---
# Must be the SAME string as `AGENT_PLATFORM_API_KEY` in the parent `agent-platform/.env`.
# If the server `.env` leaves AGENT_PLATFORM_API_KEY empty, leave this empty too.
VITE_AGENT_PLATFORM_API_KEY=

# --- API origin for browser fetches (Vite dev) ---
# Production: same-origin as `/flow`; leave unset in build if you rely on relative URLs.
# Dev: point at the running uvicorn (default port 18410).
VITE_API_ORIGIN=http://127.0.0.1:18410

# --- Optional: chat / LLM (see also model-config.ts) ---
# VITE_GEMINI_API_KEY=
# VITE_USE_GEMINI_IN_DEV=0
# VITE_OLLAMA_MODEL=
